<idea-plugin>
    <id>com.lacrearthur.claudio</id>
    <name>Claudio - Better Claude Code for Your IDE</name>
    <vendor>Arthur Scheidel</vendor>

    <description><![CDATA[
        <p><em>Early release - actively in development. This is prototype-stage software. Expect rough edges, not a polished production plugin. Feedback, bug reports, and contributions are very welcome on <a href="https://github.com/LaCreArthur/claudio">GitHub</a>.</em></p>
        <p><strong>Claude Code on steroids for JetBrains IDEs.</strong></p>
        <p>Claudio adds the missing native UX on top of the existing <code>claude code</code>, with zero compromises: all features, all models, fully compliant with Anthropic's Terms of Service.</p>

        <h2>Why Claudio is different</h2>
        <p>Most Claude integrations for IDEs re-implement the Claude API themselves - their own auth, their own proxy, their own model access. That means handing over credentials, trusting a third party, and hoping they stay within Anthropic's Terms of Service.</p>
        <p>Claudio doesn't do any of that. It runs <strong>your existing <code>claude code</code></strong> directly. Your auth is the CLI's auth. Your settings are the CLI's settings. This plugin never reads, stores, or touches your credentials - it literally cannot, because it never has access to them.</p>
        <p>The practical upside: <strong>everything Claude Code can do, Claudio can do</strong> - because it <em>is</em> Claude Code, just with a better JetBrains UX on top. New CLI features land automatically. Your existing config, your CLAUDE.md files, your MCP servers - all of it just works.</p>
        <p>It's also the only way to use Claude Code with a <strong>Max or Pro subscription</strong> inside a JetBrains IDE that's fully ToS-compliant: no API key needed, no OAuth token extraction, no workarounds.</p>

        <h2>Features</h2>
        <ul>
            <li><strong>Interactive session</strong> - full Claude Code terminal in a side panel</li>
            <li><strong>Native permission dialogs</strong> - Allow / Deny prompts as proper IDE dialogs, not raw CLI text</li>
            <li><strong>Clickable file paths</strong> - every path in Claude's output is a hyperlink; diffs jump to the first modified line</li>
            <li><strong>Send Selection</strong> (Cmd+Alt+K) - send selected editor code straight to the input bar</li>
            <li><strong>Alt+Enter on any error</strong> - "Ask Claudio about this error" injects the error + file:line into the prompt</li>
            <li><strong>@file autocomplete</strong> - type @ in the input bar to browse and insert project files by path</li>
            <li><strong>Prompt history</strong> - ↑↓ buttons to cycle previous prompts</li>
            <li><strong>Permission mode badge</strong> - live ⚡ indicator; Shift+Tab cycles modes</li>
            <li><strong>Slash command autocomplete</strong> - popup triggered by /</li>
            <li><strong>Multi-line input</strong> - Cmd+Enter for newlines, Enter to send</li>
        </ul>
        <p>Pure Kotlin + Swing. Zero runtime dependencies. No proxy, no API key.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <projectListeners>
        <listener class="com.lacrearthur.claudio.RunFailureListener"
                  topic="com.intellij.execution.ExecutionListener"/>
    </projectListeners>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Claudio" displayType="BALLOON" isLogByDefault="true"/>

        <!-- Test observability service: exposes internal state to Driver API stubs during integration tests -->
        <projectService
            serviceInterface="com.lacrearthur.claudio.test.ClaudioTestService"
            serviceImplementation="com.lacrearthur.claudio.test.ClaudioTestServiceImpl"/>

        <intentionAction>
            <language/>
            <className>com.lacrearthur.claudio.AskClaudeAboutErrorIntention</className>
            <category>Claudio</category>
        </intentionAction>

        <codeInsight.lineMarkerProvider language=""
            implementationClass="com.lacrearthur.claudio.FixWithClaudeMarkerProvider"/>

        <consoleFilterProvider implementation="com.lacrearthur.claudio.ClaudeFileFilterProvider"/>

        <searchEverywhereContributor
            implementation="com.lacrearthur.claudio.ClaudioSearchEverywhereContributorFactory"/>

        <statusBarWidgetFactory implementation="com.lacrearthur.claudio.ClaudioStatusBarWidgetFactory"
                                id="ClaudioStatus"
                                order="last"/>
        <toolWindow id="Claude"
                    anchor="right"
                    factoryClass="com.lacrearthur.claudio.ClaudeToolWindowFactory"
                    icon="/icons/claudio-icon.svg"
                    doNotActivateOnStart="true"
                    canCloseContents="false"
                    secondary="false"/>
    </extensions>

    <actions>
        <action id="com.lacrearthur.claudio.FocusClaudia"
                class="com.lacrearthur.claudio.FocusClaudiaAction"
                text="Focus Claude (Claudio)"
                description="Activate and focus the Claudio tool window">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift C"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta shift C"/>
            <keyboard-shortcut keymap="macOS" first-keystroke="meta shift C"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="ClaudeCodeGUI.SendSelectionAction"
                class="com.lacrearthur.claudio.SendSelectionAction"
                text="Send to Claude"
                description="Send selected code to Claude input bar"
                icon="/icons/send-to-terminal.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt K"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt K"/>
            <keyboard-shortcut keymap="macOS" first-keystroke="meta alt K"/>
        </action>

        <action id="com.lacrearthur.claudio.ExplainWithClaudeAction"
                class="com.lacrearthur.claudio.ExplainWithClaudeAction"
                text="Ask Claude to Explain"
                description="Send selected code to Claudio for explanation">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendVcsSelectionHistoryAction"
                class="com.lacrearthur.claudio.SendVcsSelectionHistoryAction"
                text="Send Selection History to Claude"
                description="Run git log -L on the selected line range and inject the commit history into the Claudio input bar">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="com.lacrearthur.claudio.ExplainWithClaudeAction"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendDocumentationAction"
                class="com.lacrearthur.claudio.SendDocumentationAction"
                text="Send Documentation to Claude"
                description="Fetch KDoc/Javadoc for the symbol at caret and inject it into the Claudio input bar">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="com.lacrearthur.claudio.SendVcsSelectionHistoryAction"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendUsagesAction"
                class="com.lacrearthur.claudio.SendUsagesAction"
                text="Send Usages to Claude"
                description="Run project-scope Find Usages on the symbol at caret and inject up to 50 usage sites as file:line references into the Claudio input bar">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="com.lacrearthur.claudio.SendDocumentationAction"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendHierarchyAction"
                class="com.lacrearthur.claudio.SendHierarchyAction"
                text="Send Hierarchy to Claude"
                description="Find all classes and interfaces that extend or implement the type at caret and inject up to 30 inheritors as file:line references into the Claudio input bar">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="com.lacrearthur.claudio.SendUsagesAction"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendCallHierarchyAction"
                class="com.lacrearthur.claudio.SendCallHierarchyAction"
                text="Send Call Hierarchy to Claude"
                description="Find all callers of the function or method at caret and inject up to 50 call sites as file:line references into the Claudio input bar">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="com.lacrearthur.claudio.SendHierarchyAction"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendCurrentFileAction"
                class="com.lacrearthur.claudio.SendCurrentFileAction"
                text="Send Current File to Claude"
                description="Inject @file:line reference for the current editor file into Claudio">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="ClaudeCodeGUI.SendSelectionAction"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt F"/>
            <keyboard-shortcut keymap="macOS" first-keystroke="meta alt F"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt F"/>
        </action>

        <action id="com.lacrearthur.claudio.SendTodosAction"
                class="com.lacrearthur.claudio.SendTodosAction"
                text="Send TODOs to Claude"
                description="Collect all project TODO/FIXME items and send them to Claudio">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendProjectFileAction"
                class="com.lacrearthur.claudio.SendProjectFileAction"
                text="Send to Claude"
                description="Inject @filepath into the Claudio input bar">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendDebuggerContextAction"
                class="com.lacrearthur.claudio.SendDebuggerContextAction"
                text="Send Debugger Context to Claude"
                description="Inject current debugger pause location into the Claudio input bar">
            <add-to-group group-id="XDebugger.ToolWindow.TopToolbar" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendBreakpointsAction"
                class="com.lacrearthur.claudio.SendBreakpointsAction"
                text="Send Breakpoints to Claude"
                description="Inject all active XDebugger breakpoints with file:line, enabled state, and condition expressions into the Claudio input bar">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendDiffToClaudeAction"
                class="com.lacrearthur.claudio.SendDiffToClaudeAction"
                text="Send Uncommitted Diff to Claude"
                description="Inject the full uncommitted git diff into the Claudio input bar">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendBookmarksToClaudeAction"
                class="com.lacrearthur.claudio.SendBookmarksToClaudeAction"
                text="Send Bookmarks to Claude"
                description="Inject all editor bookmarks as a file:line list into the Claudio input bar">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendRunConfigsToClaudeAction"
                class="com.lacrearthur.claudio.SendRunConfigsToClaudeAction"
                text="Send Run Configurations to Claude"
                description="Inject all run configurations (name, type, parameters) into the Claudio input bar">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendCoverageGapsAction"
                class="com.lacrearthur.claudio.SendCoverageGapsAction"
                text="Send Coverage Gaps to Claude"
                description="Inject classes with less than 80% line coverage into the Claudio input bar">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendModuleGraphAction"
                class="com.lacrearthur.claudio.SendModuleGraphAction"
                text="Send Module Graph to Claude"
                description="Inject the project module dependency tree into the Claudio input bar">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendBuildTasksAction"
                class="com.lacrearthur.claudio.SendBuildTasksAction"
                text="Send Build Tasks to Claude"
                description="Inject all available Gradle tasks grouped by category into the Claudio input bar">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendRecentFilesAction"
                class="com.lacrearthur.claudio.SendRecentFilesAction"
                text="Send Recent Files to Claude"
                description="Inject the last 15 recently opened project files into the Claudio input bar">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.RunInspectionsForClaudeAction"
                class="com.lacrearthur.claudio.RunInspectionsForClaudeAction"
                text="Run Inspections for Claude"
                description="Collect IDE daemon warnings and errors for the current file and inject them into the Claudio input bar">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.lacrearthur.claudio.SendTestHistoryAction"
                class="com.lacrearthur.claudio.SendTestHistoryAction"
                text="Send Test History to Claude"
                description="Inject the last 5 test runs from .idea/testHistory/ (pass/fail counts, duration, failure messages) into the Claudio input bar">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
